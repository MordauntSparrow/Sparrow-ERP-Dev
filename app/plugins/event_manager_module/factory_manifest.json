{
  "repository": "official",
  "system_name": "event_manager_module",
  "name": "Event Manager",
  "description": "Manage and publish upcoming business events (e.g. weddings, charity nights, wakes) with public event listings.",
  "current_version": "0.0.2",
  "compatible_with": ">=1.1.4",
  "force_update": false,
  "icon": "https://gitlab.com/sparrow-erp/Core/-/raw/main/plugins/event_manager_module/icon.png",
  "download_url": "https://gitlab.com/api/v4/projects/65546585/repository/files/plugins%2Fevent_manager_module%2Fevent_manager_module_v0.0.2.zip/raw?ref=main",
  "dependencies": ["website_module"],
  "public_sections": [
    {
      "label": "Events",
      "description": "Upcoming events and listings.",
      "url": "/events/",
      "order": 210
    }
  ],
  "public_sitemaps": [
    "/events/sitemap.xml"
  ],
  "settings": {
    "default_view": { "value": "calendar", "editable": true },
    "date_format": { "value": "DD/MM/YYYY", "editable": true },
    "allow_menu_uploads": { "value": true, "editable": true },
    "max_menu_file_size_mb": { "value": 5, "editable": true },
    "music_types": {
      "value": ["None", "DJ", "Live Band", "Other"],
      "editable": false
    }
  },
  "changelog": [
    {
      "version": "0.0.2",
      "date": "2026-01-12",
      "changes": [
        "Smart sitemap signposting: declares public sitemap endpoint for aggregation into the website module sitemap index.",
        "Adds public section discovery metadata for /llms.txt and human/AI navigation (public_sections + public_sitemaps).",
        "Compatibility alignment with core/website module update system conventions (factory current_version + API download_url)."
      ]
    },
    {
      "version": "0.0.1",
      "date": "2026-01-12",
      "changes": [
        "Initial release of Event Manager module."
      ]
    }
  ]
}
